<Window x:Class="DwemerDistro.Launcher.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dwemer Distro"
        Icon="Assets/DwemerDistro.ico"
        Width="880"
        Height="980"
        MinWidth="880"
        MinHeight="980"
        ResizeMode="NoResize"
        Background="#2C2C2C"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="DistroButton" TargetType="Button">
            <Setter Property="Background" Value="#5E0505" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#4A0404" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2C2C2C" />
            <Setter Property="BorderBrush" Value="#565656" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="Margin" Value="0,2,4,2" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Margin="0,8,0,16">
                    <Image Source="Assets/dd_title.png"
                           Width="280"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />
                </StackPanel>

                <GroupBox Header="Server Controls">
                    <StackPanel>
                        <Button Content="{Binding StartButtonText}"
                                Command="{Binding StartServerCommand}"
                                Style="{StaticResource DistroButton}" />
                        <Button Content="Stop Server"
                                Command="{Binding StopServerCommand}"
                                Style="{StaticResource DistroButton}" />
                        <Button Content="Force Stop Server"
                                Command="{Binding ForceStopServerCommand}"
                                Style="{StaticResource DistroButton}" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Updater">
                    <StackPanel>
                        <Button Content="Update"
                                Command="{Binding UpdateAllCommand}"
                                Style="{StaticResource DistroButton}" />

                        <Grid Margin="0,4,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IncludeHerikaServerUpdate}"
                                      Command="{Binding SaveUpdateIncludeCommand}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding HerikaBranches}"
                                      SelectedItem="{Binding TargetHerikaBranch}"
                                      Margin="0,0,8,0" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding HerikaStatusText}"
                                       Foreground="{Binding HerikaStatusColor}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <Grid Margin="0,2,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IncludeStobeServerUpdate}"
                                      Command="{Binding SaveUpdateIncludeCommand}" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding StobeBranches}"
                                      SelectedItem="{Binding TargetStobeBranch}"
                                      Margin="0,0,8,0" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding StobeStatusText}"
                                       Foreground="{Binding StobeStatusColor}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" />
                        </Grid>

                        <TextBlock Text="{Binding NexusVersionText}"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Server Configuration">
                    <StackPanel>
                        <Button Content="Open Server Folder"
                                Command="{Binding OpenServerFolderCommand}"
                                Style="{StaticResource DistroButton}" />
                        <Button Content="Install Components"
                                Command="{Binding InstallComponentsCommand}"
                                Style="{StaticResource DistroButton}" />
                        <Button Content="Configure Installed Components"
                                Command="{Binding ConfigureInstalledComponentsCommand}"
                                Style="{StaticResource DistroButton}" />
                        <Button Content="Debugging"
                                Command="{Binding OpenDebuggingCommand}"
                                Style="{StaticResource DistroButton}" />
                        <CheckBox Content="Enable MCP Service (default ON)"
                                  IsChecked="{Binding McpEnabled}"
                                  Command="{Binding SaveMcpEnabledCommand}"
                                  Margin="0,6,0,0"
                                  FontWeight="Bold" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="External Links">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Wiki"
                                Command="{Binding OpenWikiCommand}"
                                Style="{StaticResource DistroButton}"
                                Width="100"
                                Background="#808080"
                                Margin="5" />
                        <Button Content="Discord"
                                Command="{Binding OpenDiscordCommand}"
                                Style="{StaticResource DistroButton}"
                                Width="100"
                                Background="#5865F2"
                                Margin="5" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Launcher">
                    <StackPanel>
                        <TextBlock Text="{Binding LauncherVersionText}"
                                   FontSize="10"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{Binding LauncherUpdateStatusText}"
                                   Foreground="{Binding LauncherUpdateStatusColor}"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,0,0,6" />
                        <Button Content="{Binding LauncherUpdateButtonText}"
                                Command="{Binding UpdateLauncherCommand}"
                                Style="{StaticResource DistroButton}"
                                IsEnabled="{Binding CanUpdateLauncher}" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="2" Background="#1E1E1E">
            <TextBox x:Name="OutputTextBox"
                     Text="{Binding OutputText, Mode=OneWay}"
                     TextChanged="OutputTextBox_TextChanged"
                     Background="#1E1E1E"
                     Foreground="White"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="10"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     IsReadOnly="True" />
        </Border>
    </Grid>
</Window>
