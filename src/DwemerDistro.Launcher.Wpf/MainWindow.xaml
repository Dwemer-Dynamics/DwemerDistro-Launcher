<Window x:Class="DwemerDistro.Launcher.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Dwemer Distro"
        Icon="Assets/DwemerDistro.ico"
        Width="930"
        Height="980"
        MinWidth="880"
        MinHeight="820"
        MaxWidth="1460"
        MaxHeight="1400"
        ResizeMode="CanResize"
        Background="#2C2C2C"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="BaseControlButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#4F545A" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#7E8791" />
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.95" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryControlButton" TargetType="Button" BasedOn="{StaticResource BaseControlButton}">
            <Setter Property="Background" Value="#651010" />
            <Setter Property="BorderBrush" Value="#8A2B2B" />
        </Style>

        <Style x:Key="SecondaryControlButton" TargetType="Button" BasedOn="{StaticResource BaseControlButton}">
            <Setter Property="Background" Value="#303338" />
            <Setter Property="BorderBrush" Value="#4F545A" />
        </Style>

        <Style x:Key="SuccessControlButton" TargetType="Button" BasedOn="{StaticResource BaseControlButton}">
            <Setter Property="Background" Value="#2E7D39" />
            <Setter Property="BorderBrush" Value="#4FA45B" />
        </Style>

        <Style x:Key="WarningControlButton" TargetType="Button" BasedOn="{StaticResource BaseControlButton}">
            <Setter Property="Background" Value="#875315" />
            <Setter Property="BorderBrush" Value="#B17A36" />
        </Style>

        <Style x:Key="DangerControlButton" TargetType="Button" BasedOn="{StaticResource BaseControlButton}">
            <Setter Property="Background" Value="#B31717" />
            <Setter Property="BorderBrush" Value="#E14A4A" />
        </Style>

        <Style x:Key="LauncherUpdateControlButton" TargetType="Button" BasedOn="{StaticResource BaseControlButton}">
            <Setter Property="Background" Value="#303338" />
            <Setter Property="BorderBrush" Value="#4F545A" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Background" Value="#2E7D39" />
                    <Setter Property="BorderBrush" Value="#4FA45B" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#1F1F1F" />
            <Setter Property="BorderBrush" Value="#565656" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="SectionCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CFCFCF" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,3,0,0" />
        </Style>

        <Style x:Key="SmallLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D5D5D5" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinWidth" Value="92" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource SectionCard}"
                        Padding="12,10">
                    <StackPanel>
                        <Image Source="Assets/dd_title.png"
                               Width="250"
                               Stretch="Uniform"
                               HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Startup"
                                   Style="{StaticResource SectionTitle}" />
                        <Button Command="{Binding StartServerCommand}"
                                Style="{StaticResource SuccessControlButton}"
                                Margin="0,10,0,6">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M 0 0 L 0 10 L 8 5 Z"
                                          Fill="White"
                                          Width="8"
                                          Height="10"
                                          Stretch="Fill"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StartButtonText}"
                                               Foreground="White"
                                               FontFamily="Trebuchet MS"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        <Button Command="{Binding StopServerCommand}"
                                Style="{StaticResource PrimaryControlButton}">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="9"
                                               Height="9"
                                               Fill="White"
                                               RadiusX="1"
                                               RadiusY="1"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Stop Server"
                                               Foreground="White"
                                               FontFamily="Trebuchet MS"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        <Button Command="{Binding ForceStopServerCommand}"
                                Style="{StaticResource DangerControlButton}"
                                Margin="0,0,0,0">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="10"
                                             Height="10"
                                             Margin="0,0,8,0">
                                        <Canvas Width="10"
                                                Height="10">
                                            <Path Data="M 1 1 L 9 9 M 9 1 L 1 9"
                                                  Stroke="White"
                                                  StrokeThickness="1.7"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Force Stop Server"
                                               Foreground="White"
                                               FontFamily="Trebuchet MS"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,10,0">
                                <TextBlock Text="Mod Updates"
                                           Style="{StaticResource SectionTitle}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Command="{Binding UpdateAllCommand}"
                                    Style="{StaticResource SuccessControlButton}"
                                    HorizontalContentAlignment="Center"
                                    MinWidth="96"
                                    Margin="0,0,0,0"
                                    VerticalAlignment="Center">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12"
                                                 Height="12"
                                                 Margin="0,0,8,0">
                                            <Canvas Width="12"
                                                    Height="12">
                                                <Path Data="M 6 1 L 6 7 M 3.5 4.5 L 6 7 L 8.5 4.5 M 2 10 L 10 10"
                                                      Stroke="White"
                                                      StrokeThickness="1.4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="Update"
                                                   Foreground="White"
                                                   FontFamily="Trebuchet MS"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </Grid>

                        <Border Margin="0,10,0,0"
                                Padding="10"
                                Background="#262626"
                                BorderBrush="#4B4B4B"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="HerikaServer"
                                           Style="{StaticResource SmallLabel}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              Content="Include"
                                              IsChecked="{Binding IncludeHerikaServerUpdate}"
                                              Command="{Binding SaveUpdateIncludeCommand}" />
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding HerikaBranches}"
                                              SelectedItem="{Binding TargetHerikaBranch}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding HerikaStatusText}"
                                               Foreground="{Binding HerikaStatusColor}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,8,0,0"
                                Padding="10"
                                Background="#262626"
                                BorderBrush="#4B4B4B"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <TextBlock Text="StobeServer"
                                           Style="{StaticResource SmallLabel}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              Content="Include"
                                              IsChecked="{Binding IncludeStobeServerUpdate}"
                                              Command="{Binding SaveUpdateIncludeCommand}" />
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding StobeBranches}"
                                              SelectedItem="{Binding TargetStobeBranch}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding StobeStatusText}"
                                               Foreground="{Binding StobeStatusColor}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding NexusVersionText}"
                                   Style="{StaticResource SectionCaption}"
                                   Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="Server Configuration"
                                   Style="{StaticResource SectionTitle}" />
                        <Button Command="{Binding OpenServerFolderCommand}"
                                Style="{StaticResource PrimaryControlButton}"
                                Margin="0,10,0,6">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12"
                                             Height="12"
                                             Margin="0,0,8,0">
                                        <Canvas Width="12"
                                                Height="12">
                                            <Path Data="M 1 3 L 4.5 3 L 5.8 4.6 L 11 4.6 L 11 10.5 L 1 10.5 Z"
                                                  Fill="White" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Open Server Folder"
                                               Foreground="White"
                                               FontFamily="Trebuchet MS"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        <Button Command="{Binding InstallComponentsCommand}"
                                Style="{StaticResource PrimaryControlButton}">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12"
                                             Height="12"
                                             Margin="0,0,8,0">
                                        <Canvas Width="12"
                                                Height="12">
                                            <Path Data="M 4 1 L 4 3 M 8 1 L 8 3 M 3 3.2 L 9 3.2 L 9 7 L 7 7 L 7 10.5 L 5 10.5 L 5 7 L 3 7 Z"
                                                  Stroke="White"
                                                  StrokeThickness="1.3"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Install Components"
                                               Foreground="White"
                                               FontFamily="Trebuchet MS"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        <Button Command="{Binding ConfigureInstalledComponentsCommand}"
                                Style="{StaticResource PrimaryControlButton}">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12"
                                             Height="12"
                                             Margin="0,0,8,0">
                                        <Canvas Width="12"
                                                Height="12">
                                            <Ellipse Width="5.4"
                                                     Height="5.4"
                                                     Stroke="White"
                                                     StrokeThickness="1.15"
                                                     Canvas.Left="3.3"
                                                     Canvas.Top="3.3" />
                                            <Path Data="M 6 0.8 L 6 2 M 6 10 L 6 11.2 M 0.8 6 L 2 6 M 10 6 L 11.2 6 M 2.2 2.2 L 3 3 M 9 9 L 9.8 9.8 M 9 3 L 9.8 2.2 M 2.2 9.8 L 3 9"
                                                  Stroke="White"
                                                  StrokeThickness="1.15"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Configure Installed Components"
                                               Foreground="White"
                                               FontFamily="Trebuchet MS"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>
                        <Button Command="{Binding OpenDebuggingCommand}"
                                Style="{StaticResource PrimaryControlButton}"
                                Margin="0,0,0,0">
                            <Button.Content>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="12"
                                             Height="12"
                                             Margin="0,0,8,0">
                                        <Canvas Width="12"
                                                Height="12">
                                            <Ellipse Width="4"
                                                     Height="3"
                                                     Fill="White"
                                                     Canvas.Left="4"
                                                     Canvas.Top="1.2" />
                                            <Ellipse Width="5.8"
                                                     Height="6.2"
                                                     Stroke="White"
                                                     StrokeThickness="1.15"
                                                     Canvas.Left="3.1"
                                                     Canvas.Top="4" />
                                            <Path Data="M 5 1.4 L 4 0 M 7 1.4 L 8 0 M 4.4 6.5 L 1.6 5.2 M 4 8.2 L 1.2 8.2 M 4.4 10 L 1.6 11.4 M 7.6 6.5 L 10.4 5.2 M 8 8.2 L 10.8 8.2 M 7.6 10 L 10.4 11.4"
                                                  Stroke="White"
                                                  StrokeThickness="1.05"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="Debugging"
                                               Foreground="White"
                                               FontFamily="Trebuchet MS"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button.Content>
                        </Button>

                        <Border Margin="0,10,0,0"
                                Padding="10"
                                Background="#262626"
                                BorderBrush="#4B4B4B"
                                BorderThickness="1"
                                CornerRadius="6">
                            <CheckBox Content="Enable MCP Service (default ON)"
                                      IsChecked="{Binding McpEnabled}"
                                      Command="{Binding SaveMcpEnabledCommand}"
                                      FontWeight="Bold" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,10,0">
                                <TextBlock Text="Launcher Updates"
                                           Style="{StaticResource SectionTitle}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Command="{Binding UpdateLauncherCommand}"
                                    Style="{StaticResource LauncherUpdateControlButton}"
                                    IsEnabled="{Binding CanUpdateLauncher}"
                                    HorizontalContentAlignment="Center"
                                    Margin="0,0,0,0"
                                    VerticalAlignment="Center">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="12"
                                                 Height="12"
                                                 Margin="0,0,8,0">
                                            <Canvas Width="12"
                                                    Height="12">
                                                <Path Data="M 6 1 L 6 7 M 3.5 4.5 L 6 7 L 8.5 4.5 M 2 10 L 10 10"
                                                      Stroke="White"
                                                      StrokeThickness="1.4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="{Binding LauncherUpdateButtonText}"
                                                   Foreground="White"
                                                   FontFamily="Trebuchet MS"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </Grid>

                        <TextBlock Text="{Binding LauncherVersionText}"
                                   Style="{StaticResource SmallLabel}"
                                   Margin="0,10,0,4" />
                        <TextBlock Text="{Binding LauncherUpdateStatusText}"
                                   Foreground="{Binding LauncherUpdateStatusColor}"
                                   Style="{StaticResource SectionCaption}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="External Links"
                                   Style="{StaticResource SectionTitle}" />

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0"
                                    Grid.Column="0"
                                    Command="{Binding OpenChimCommand}"
                                    Style="{StaticResource BaseControlButton}"
                                    HorizontalContentAlignment="Center"
                                    Background="#F27C11"
                                    BorderBrush="#F5A24D"
                                    Margin="0,0,6,6">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="Assets/chim-icon.png"
                                               Width="14"
                                               Height="14"
                                               Stretch="Uniform"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="CHIM"
                                                   Foreground="White"
                                                   FontFamily="Trebuchet MS"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Grid.Row="0"
                                    Grid.Column="1"
                                    Command="{Binding OpenStobeCommand}"
                                    Style="{StaticResource BaseControlButton}"
                                    HorizontalContentAlignment="Center"
                                    Background="#B9934B"
                                    BorderBrush="#DFC184"
                                    Margin="6,0,0,6">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="Assets/stobe-icon.png"
                                               Width="14"
                                               Height="14"
                                               Stretch="Uniform"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="STOBE"
                                                   Foreground="White"
                                                   FontFamily="Trebuchet MS"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Grid.Row="1"
                                    Grid.Column="0"
                                    Command="{Binding OpenWikiCommand}"
                                    Style="{StaticResource BaseControlButton}"
                                    HorizontalContentAlignment="Center"
                                    Background="#4A4F57"
                                    BorderBrush="#707782"
                                    Margin="0,0,6,0">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Viewbox Width="14"
                                                 Height="14"
                                                 Margin="0,0,8,0">
                                            <Canvas Width="14"
                                                    Height="14">
                                                <Ellipse Width="11"
                                                         Height="11"
                                                         Stroke="White"
                                                         StrokeThickness="1.2"
                                                         Canvas.Left="1.5"
                                                         Canvas.Top="1.5" />
                                                <Path Data="M 7 1.8 C 9.2 4.2 9.2 9.8 7 12.2 C 4.8 9.8 4.8 4.2 7 1.8 M 2 7 L 12 7 M 3 4.2 C 5.8 5.3 8.2 5.3 11 4.2 M 3 9.8 C 5.8 8.7 8.2 8.7 11 9.8"
                                                      Stroke="White"
                                                      StrokeThickness="1"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round" />
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="Wiki"
                                                   Foreground="White"
                                                   FontFamily="Trebuchet MS"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Grid.Row="1"
                                    Grid.Column="1"
                                    Command="{Binding OpenDiscordCommand}"
                                    Style="{StaticResource BaseControlButton}"
                                    HorizontalContentAlignment="Center"
                                    Background="#5865F2"
                                    BorderBrush="#7A85FF"
                                    Margin="6,0,0,0">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="Assets/discord.png"
                                               Width="14"
                                               Height="14"
                                               Stretch="Uniform"
                                               Margin="0,0,8,0" />
                                        <TextBlock Text="Discord"
                                                   Foreground="White"
                                                   FontFamily="Trebuchet MS"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="2"
                Background="#1E1E1E"
                BorderBrush="#565656"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Background="#242424"
                        BorderBrush="#565656"
                        BorderThickness="0,0,0,1"
                        Padding="12,9">
                    <StackPanel>
                        <TextBlock Text="Output Console"
                                   Foreground="White"
                                   FontFamily="Trebuchet MS"
                                   FontSize="13"
                                   FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <RichTextBox x:Name="OutputRichTextBox"
                             Background="#1E1E1E"
                             Foreground="White"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="13"
                             IsReadOnly="True"
                             IsDocumentEnabled="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled" />
            </DockPanel>
