<Window x:Class="DwemerDistro.Launcher.Wpf.Views.DebuggingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debugging"
        Icon="/Assets/DwemerDistro.ico"
        Width="440"
        Height="900"
        ResizeMode="NoResize"
        Background="#2C2C2C">
    <Window.Resources>
        <Style x:Key="DebugButton" TargetType="Button">
            <Setter Property="Background" Value="#5E0505" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="300" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#4A0404" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DebugHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,8,0,5" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" HorizontalAlignment="Center">
            <Image Source="/Assets/dd_title.png"
                   Width="240"
                   Stretch="Uniform"
                   Margin="0,0,0,12" />
            <TextBlock Style="{StaticResource DebugHeader}" Text="--- Diagnostics ---" />
            <Button Content="Create Diagnostic File"
                    Command="{Binding GenerateDiagnosticsCommand}"
                    Style="{StaticResource DebugButton}" />

            <Separator Margin="0,10" />
            <TextBlock Style="{StaticResource DebugHeader}" Text="--- Distro Actions ---" />
            <Button Content="Open Terminal"
                    Command="{Binding OpenTerminalCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="View Memory Usage"
                    Command="{Binding ViewMemoryUsageCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="Rollback HerikaServer"
                    Command="{Binding OpenHerikaRollbackCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="Rollback StobeServer"
                    Command="{Binding OpenStobeRollbackCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="Fix WSL DNS (GitHub)"
                    Command="{Binding FixWslDnsCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="Configure CUDA GPU"
                    Command="{Binding OpenCudaConfigCommand}"
                    Style="{StaticResource DebugButton}" />

            <Separator Margin="0,10" />
            <TextBlock Style="{StaticResource DebugHeader}" Text="--- View Logs ---" />
            <Button Content="View Dwemer Distro XTTS Logs"
                    Command="{Binding ViewXttsLogsCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="View Chatterbox Logs"
                    Command="{Binding ViewChatterboxLogsCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="View PocketTTS Logs"
                    Command="{Binding ViewPocketTtsLogsCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="View MeloTTS Logs"
                    Command="{Binding ViewMeloTtsLogsCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="View Piper Logs"
                    Command="{Binding ViewPiperLogsCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="View LocalWhisper Logs"
                    Command="{Binding ViewLocalWhisperLogsCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="View Parakeet Logs"
                    Command="{Binding ViewParakeetLogsCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="View Apache Logs"
                    Command="{Binding ViewApacheLogsCommand}"
                    Style="{StaticResource DebugButton}" />
            <Button Content="Clean All Logs"
                    Command="{Binding CleanLogsCommand}"
                    Style="{StaticResource DebugButton}" />
        </StackPanel>
    </ScrollViewer>
</Window>
