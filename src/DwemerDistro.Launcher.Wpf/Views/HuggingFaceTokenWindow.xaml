<Window x:Class="DwemerDistro.Launcher.Wpf.Views.HuggingFaceTokenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hugging Face Token"
        Icon="/Assets/DwemerDistro.ico"
        Width="540"
        Height="320"
        MinWidth="500"
        ResizeMode="NoResize"
        Background="#2C2C2C"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#5E0505" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="5,0" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#4A0404" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#404040" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,10">
            <Image Source="/Assets/huggingface.png"
                   Width="22"
                   Height="22"
                   Stretch="Uniform"
                   Margin="0,0,8,0" />
            <TextBlock Text="Hugging Face Token"
                       FontSize="15"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="Stored for the WSL dwemer user at ~/.cache/huggingface/token."
                   Foreground="#CCCCCC"
                   FontSize="11"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="2"
              Margin="0,0,0,8">
            <PasswordBox x:Name="TokenPasswordBox"
                         Padding="9,7"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="#1E1E1E"
                         Foreground="White"
                         BorderBrush="#565656"
                         BorderThickness="1" />
            <TextBox x:Name="TokenTextBox"
                     Padding="9,7"
                     FontFamily="Consolas"
                     FontSize="12"
                     Background="#1E1E1E"
                     Foreground="White"
                     BorderBrush="#565656"
                     BorderThickness="1"
                     Visibility="Collapsed" />
        </Grid>

        <CheckBox Grid.Row="3"
                  x:Name="ShowTokenCheckBox"
                  Content="Show token"
                  Checked="ShowTokenCheckBox_Checked"
                  Unchecked="ShowTokenCheckBox_Unchecked"
                  Margin="0,0,0,10" />

        <TextBlock Grid.Row="4"
                   Text="Pocket-TTS may still require accepting gated model access on Hugging Face before downloads succeed."
                   Foreground="#CCCCCC"
                   FontSize="10"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button Content="Save"
                    Click="SaveButton_Click"
                    Style="{StaticResource ActionButton}" />
            <Button Content="Clear"
                    Click="ClearButton_Click"
                    Style="{StaticResource SecondaryButton}" />
            <Button Content="Cancel"
                    Click="CancelButton_Click"
                    Style="{StaticResource SecondaryButton}" />
        </StackPanel>
    </Grid>
</Window>
