<Window x:Class="DwemerDistro.Launcher.Wpf.Views.InstallComponentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Install Components"
        Icon="/Assets/DwemerDistro.ico"
        Width="840"
        Height="880"
        MinWidth="760"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#2C2C2C">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PrimaryActionButton" TargetType="Button">
            <Setter Property="Background" Value="#5E0505" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#4A0404" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InstallActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
            <Setter Property="Background" Value="#2F8F3A" />
            <Setter Property="MinWidth" Value="128" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Content" Value="Reinstall">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#5E0505" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#256F2E" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Content" Value="Reinstall" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#4A0404" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryActionButton" TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
            <Setter Property="Background" Value="#404040" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFD700" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,18,0,8" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,12"
                Padding="14"
                Background="#1E1E1E"
                BorderBrush="#565656"
                BorderThickness="1"
                CornerRadius="6">
            <Border Background="#252525"
                    BorderBrush="#565656"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Background="#263827"
                            BorderBrush="#565656"
                            BorderThickness="0,0,1,1"
                            Padding="10,8">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Image Source="/Assets/nvidia.png"
                                   Width="18"
                                   Height="18"
                                   Stretch="Uniform"
                                   Margin="0,0,8,0" />
                            <TextBlock Text="NVIDIA / CUDA"
                                       Foreground="#CFEFCF"
                                       FontFamily="Trebuchet MS"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Background="#3A3224"
                            BorderBrush="#565656"
                            BorderThickness="0,0,0,1"
                            Padding="10,8">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Image Source="/Assets/amd.png"
                                   Width="18"
                                   Height="18"
                                   Stretch="Uniform"
                                   Margin="0,0,8,0" />
                            <TextBlock Text="AMD / CPU"
                                       Foreground="#F4D8A6"
                                       FontFamily="Trebuchet MS"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="0"
                            BorderBrush="#565656"
                            BorderThickness="0,0,1,0"
                            Padding="10,8">
                        <TextBlock Text="Install CUDA before enabling GPU-backed services."
                                   Foreground="#DDDDDD"
                                   FontFamily="Trebuchet MS"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            BorderBrush="#565656"
                            BorderThickness="0,0,0,0"
                            Padding="10,8">
                        <TextBlock Text="Skip CUDA and use CPU mode where the service offers it."
                                   Foreground="#DDDDDD"
                                   FontFamily="Trebuchet MS"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Sections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       Style="{StaticResource SectionHeader}" />

                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Padding="14"
                                                Background="#262626"
                                                BorderBrush="#565656"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0"
                                                                Margin="0,0,16,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Title}"
                                                                       Foreground="White"
                                                                       FontFamily="Trebuchet MS"
                                                                       FontSize="15"
                                                                       FontWeight="Bold"
                                                                       VerticalAlignment="Center" />
                                                            <Image Source="/Assets/nvidia.png"
                                                                   Width="14"
                                                                   Height="14"
                                                                   Stretch="Uniform"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding SupportsNvidiaCuda, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                            <Image Source="/Assets/amd.png"
                                                                   Width="14"
                                                                   Height="14"
                                                                   Stretch="Uniform"
                                                                   Margin="6,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding SupportsAmdCpu, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="#DDDDDD"
                                                                   FontFamily="Trebuchet MS"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,6,0,0" />
                                                    </StackPanel>

                                                    <Border Grid.Column="1"
                                                            Background="{Binding StatusBackground}"
                                                            CornerRadius="12"
                                                            Padding="10,4"
                                                            VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding StatusText}"
                                                                   Foreground="{Binding StatusForeground}"
                                                                   FontFamily="Trebuchet MS"
                                                                   FontSize="11"
                                                                   FontWeight="Bold" />
                                                    </Border>
                                                </Grid>

                                                <StackPanel Grid.Row="1"
                                                            Margin="0,14,0,0">
                                                    <Button Content="{Binding PrimaryButtonText}"
                                                            Command="{Binding PrimaryCommand}"
                                                            Style="{StaticResource InstallActionButton}"
                                                            HorizontalAlignment="Left" />
                                                    <Button Content="{Binding SecondaryActionText}"
                                                            Command="{Binding SecondaryActionCommand}"
                                                            Style="{StaticResource SecondaryActionButton}"
                                                            HorizontalAlignment="Left"
                                                            Visibility="{Binding HasSecondaryAction, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
