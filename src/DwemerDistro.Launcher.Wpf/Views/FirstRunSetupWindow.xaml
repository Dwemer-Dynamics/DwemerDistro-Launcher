<Window x:Class="DwemerDistro.Launcher.Wpf.Views.FirstRunSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DwemerDistro Quickstart"
        Icon="/Assets/DwemerDistro.ico"
        Width="820"
        Height="680"
        MinWidth="760"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="#2C2C2C"
        TextElement.Foreground="White">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#5E0505" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#7A2828" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#2F8F3A" />
            <Setter Property="BorderBrush" Value="#4FA45B" />
            <Setter Property="MinWidth" Value="168" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#404040" />
            <Setter Property="BorderBrush" Value="#565656" />
            <Setter Property="MinWidth" Value="96" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="BorderBrush" Value="#565656" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="DetailPanel" TargetType="Border" BasedOn="{StaticResource Panel}">
            <Setter Property="Background" Value="#262626" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Trebuchet MS" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#191919" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="#5E0505" />
            <Setter Property="BorderBrush" Value="#565656" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#191919" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="SelectionBrush" Value="#5E0505" />
            <Setter Property="BorderBrush" Value="#565656" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top"
                Style="{StaticResource Panel}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Source="/Assets/DwemerDistro.png"
                       Width="42"
                       Height="42"
                       Stretch="Uniform"
                       Margin="0,0,12,0" />

                <StackPanel Grid.Column="1">
                    <TextBlock Text="DwemerDistro Quickstart"
                               FontSize="18"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding StepSubtitle}"
                               Foreground="#D6D6D6"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Border Background="#404040"
                            CornerRadius="12"
                            Padding="10,4"
                            HorizontalAlignment="Right">
                        <TextBlock Text="{Binding CurrentStepLabel}"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="Bold" />
                    </Border>
                    <Border Background="#3A3224"
                            CornerRadius="12"
                            Padding="10,4"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Right"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding BusyText}"
                                   Foreground="#F4D8A6"
                                   FontSize="11"
                                   FontWeight="Bold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Style="{StaticResource Panel}"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Back"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource SecondaryButton}" />
                <Button Grid.Column="1"
                        Content="{Binding DetailsButtonText}"
                        Command="{Binding ToggleTechnicalDetailsCommand}"
                        Style="{StaticResource SecondaryButton}" />

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal">
                    <Button Content="{Binding PrimaryContinueText}"
                            Command="{Binding ContinueCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Visibility="{Binding ShowContinueButton, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <StackPanel Visibility="{Binding IsSetupStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,16,0">
                                <TextBlock Text="{Binding StepTitle}"
                                           FontSize="20"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding HardwareSummary}"
                                           Foreground="#FFD700"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Margin="0,8,0,0" />
                                <TextBlock Text="{Binding HardwareDetail}"
                                           Foreground="#D6D6D6"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                                <TextBlock Text="{Binding SelectedPresetTitle}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,16,0,0" />
                                <TextBlock Text="{Binding SelectedPresetDescription}"
                                           Foreground="#D6D6D6"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0" />
                                <Border Background="#262626"
                                        BorderBrush="#4B4B4B"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10"
                                        Margin="0,14,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Other Setup Paths"
                                                   Foreground="#FFD700"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Margin="0,0,0,8" />
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="NVIDIA Powerful"
                                                    Command="{Binding SelectNvidiaPowerfulCommand}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Visibility="{Binding ShowNvidiaPowerfulSwitch, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="NVIDIA Standard"
                                                    Command="{Binding SelectNvidiaStandardCommand}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Visibility="{Binding ShowNvidiaStandardSwitch, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            <Button Content="AMD / CPU"
                                                    Command="{Binding SelectAmdCpuCommand}"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Visibility="{Binding ShowAmdCpuSwitch, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <Button Content="{Binding InstallRecommendedButtonText}"
                                        Command="{Binding InstallRecommendedCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Left"
                                        Margin="0,18,0,0" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{Binding SetupStatusBackground}"
                                    CornerRadius="14"
                                    Padding="12,5"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding SetupStatusText}"
                                           FontSize="11"
                                           FontWeight="Bold" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DetailPanel}"
                            Visibility="{Binding ShowTechnicalDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Install Details"
                                       Foreground="#FFD700"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10" />
                            <ItemsControl ItemsSource="{Binding SetupComponents}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="#D6D6D6"
                                                           TextWrapping="Wrap"
                                                           FontSize="11" />
                                                <TextBlock Text="{Binding DetailText}"
                                                           Foreground="#D79C9C"
                                                           TextWrapping="Wrap"
                                                           FontSize="11"
                                                           Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Background="{Binding StatusBackground}"
                                                    CornerRadius="12"
                                                    Padding="10,4"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="11"
                                                           FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBox Text="{Binding SetupLogText, Mode=OneWay}"
                                     Height="110"
                                     Margin="0,8,0,0"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     VerticalScrollBarVisibility="Auto" />
                            <Button Content="Refresh"
                                    Command="{Binding RefreshSetupCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Visibility="{Binding IsOpenRouterStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,16,0">
                                <TextBlock Text="{Binding StepTitle}"
                                           FontSize="20"
                                           FontWeight="Bold" />
                                <TextBlock Text="Paste the key once. The launcher applies it to CHIM, STOBE, and Dialectic when those databases are installed."
                                           Foreground="#D6D6D6"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                                <Button Content="Open OpenRouter Keys"
                                        Command="{Binding OpenOpenRouterKeysCommand}"
                                        Style="{StaticResource SecondaryButton}"
                                        HorizontalAlignment="Left"
                                        Margin="0,16,0,0" />
                                <PasswordBox x:Name="OpenRouterPasswordBox"
                                             PasswordChanged="OpenRouterPasswordBox_PasswordChanged"
                                             Margin="0,12,0,0" />
                                <Button Content="Apply Key"
                                        Command="{Binding SaveOpenRouterCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Left"
                                        Margin="0,12,0,0" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{Binding OpenRouterStatusBackground}"
                                    CornerRadius="14"
                                    Padding="12,5"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding OpenRouterStatusText}"
                                           FontSize="11"
                                           FontWeight="Bold" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DetailPanel}"
                            Visibility="{Binding ShowTechnicalDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="OpenRouter Targets"
                                       Foreground="#FFD700"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10" />
                            <ItemsControl ItemsSource="{Binding OpenRouterTargets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="{Binding DetailText}"
                                                           Foreground="#D79C9C"
                                                           TextWrapping="Wrap"
                                                           FontSize="11"
                                                           Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Background="{Binding StatusBackground}"
                                                    CornerRadius="12"
                                                    Padding="10,4"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="11"
                                                           FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Refresh"
                                    Command="{Binding RefreshOpenRouterCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Visibility="{Binding IsHuggingFaceStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,16,0">
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Assets/huggingface.png"
                                           Width="22"
                                           Height="22"
                                           Stretch="Uniform"
                                           Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding StepTitle}"
                                               FontSize="20"
                                               FontWeight="Bold" />
                                </StackPanel>
                                <TextBlock Text="{Binding HuggingFaceStatusDetail}"
                                           Foreground="#D6D6D6"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,16,0,0">
                                    <Button Content="Open Token Page"
                                            Command="{Binding OpenHuggingFaceTokensCommand}"
                                            Style="{StaticResource SecondaryButton}" />
                                    <Button Content="Open Voice Model Pages"
                                            Command="{Binding OpenHuggingFaceModelAccessCommand}"
                                            Style="{StaticResource SecondaryButton}" />
                                </StackPanel>
                                <PasswordBox x:Name="HuggingFacePasswordBox"
                                             PasswordChanged="HuggingFacePasswordBox_PasswordChanged"
                                             Margin="0,12,0,0" />
                                <Button Content="Save and Verify"
                                        Command="{Binding SaveHuggingFaceCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Left"
                                        Margin="0,12,0,0" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{Binding HuggingFaceStatusBackground}"
                                    CornerRadius="14"
                                    Padding="12,5"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding HuggingFaceStatusText}"
                                           FontSize="11"
                                           FontWeight="Bold" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DetailPanel}"
                            Visibility="{Binding ShowTechnicalDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Hugging Face Model Access"
                                       Foreground="#FFD700"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10" />
                            <ItemsControl ItemsSource="{Binding HuggingFaceModelAccessItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="{Binding RepositoryId}"
                                                           Foreground="#FFD700"
                                                           FontSize="11" />
                                                <TextBlock Text="{Binding DetailText}"
                                                           Foreground="#D6D6D6"
                                                           TextWrapping="Wrap"
                                                           FontSize="11" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Background="{Binding StatusBackground}"
                                                    CornerRadius="12"
                                                    Padding="10,4"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="11"
                                                           FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Refresh"
                                    Command="{Binding RefreshHuggingFaceCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Visibility="{Binding IsReadyStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Border Style="{StaticResource Panel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0"
                                        Margin="0,0,16,0">
                                <TextBlock Text="{Binding StepTitle}"
                                           FontSize="20"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding VoiceStatusDetail}"
                                           Foreground="#D6D6D6"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                                <TextBlock Text="{Binding ReadySummary}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           Margin="0,18,0,0" />
                                <Button Content="Start Server"
                                        Command="{Binding StartServerCommand}"
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Left"
                                        Margin="0,18,0,0" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{Binding VoiceStatusBackground}"
                                    CornerRadius="14"
                                    Padding="12,5"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding VoiceStatusText}"
                                           FontSize="11"
                                           FontWeight="Bold" />
                            </Border>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DetailPanel}"
                            Visibility="{Binding ShowTechnicalDetails, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Voice Apply Targets"
                                       Foreground="#FFD700"
                                       FontWeight="Bold"
                                       Margin="0,0,0,10" />
                            <ItemsControl ItemsSource="{Binding VoiceApplyTargets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0"
                                                        Margin="0,0,12,0">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="Bold" />
                                                <TextBlock Text="{Binding DetailText}"
                                                           Foreground="#D79C9C"
                                                           TextWrapping="Wrap"
                                                           FontSize="11"
                                                           Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Background="{Binding StatusBackground}"
                                                    CornerRadius="12"
                                                    Padding="10,4"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="11"
                                                           FontWeight="Bold" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Refresh"
                                    Command="{Binding RefreshReadyCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
